MDScreen:
    name: "page_inscription"

    MDBoxLayout:
        orientation: "vertical"
        padding: "20dp"
        spacing: "15dp"
        pos_hint: {"center_y": 0.5}
        adaptive_height: True

        MDLabel:
            text: "Créer un compte"
            font_style: "H4"
            halign: "center"
            bold: True
            theme_text_color: "Primary"

        MDTextField:
            id: champ_nom_insc
            hint_text: "Nom"
            mode: "rectangle"

        MDTextField:
            id: champ_prenom_insc
            hint_text: "Prénom"
            mode: "rectangle"

        MDTextField:
            id: champ_email_insc
            hint_text: "Adresse Email"
            icon_right: "email"
            mode: "rectangle"

        MDTextField:
            id: champ_mdp_insc
            hint_text: "Mot de passe"
            icon_right: "eye-off"
            mode: "rectangle"
            password: True

        MDLabel:
            id: message_erreur_insc
            text: ""
            theme_text_color: "Error" # Devient vert en cas de succès
            halign: "center"
            size_hint_y: None
            height: self.texture_size[1]

        MDRaisedButton:
            text: "S'INSCRIRE"
            pos_hint: {"center_x": 0.5}
            size_hint_x: 0.8
            md_bg_color: "#691C32"
            on_release: app.tenter_inscription(champ_nom_insc.text, champ_prenom_insc.text, champ_email_insc.text, champ_mdp_insc.text)

        MDTextButton:
            text: "Déjà un compte ? Se connecter"
            pos_hint: {"center_x": 0.5}
            theme_text_color: "Secondary"
            on_release: app.aller_a_connexion()