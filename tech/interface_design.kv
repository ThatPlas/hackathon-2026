#:import dp kivy.metrics.dp

BoxLayout:
    id: root_layout
    orientation: "vertical"

    ScreenManager:
        id: screen_manager

        Screen:
            name: "login_screen"
            MDBoxLayout:
                orientation: "vertical"
                padding: dp(20)
                spacing: dp(20)

                MDTextField:
                    id: login_email
                    hint_text: "Email"

                MDTextField:
                    id: login_password
                    hint_text: "Mot de passe"
                    password: True

                MDRaisedButton:
                    text: "Se connecter"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.tenter_connexion(login_email.text, login_password.text)

                MDLabel:
                    id: login_msg
                    text: ""
                    theme_text_color: "Error"
                    halign: "center"

        Screen:
            name: "main_screen"
            MDScreen:
                md_bg_color: 0.96, 0.96, 0.96, 1
                MDBottomNavigation:
                    id: nav_bar
                    panel_color: "#F7F5F5"
                    text_color_active: "#691C32"

                    MDBottomNavigationItem:
                        name: 'recherche'
                        icon: 'clipboard-text-clock'
                        MDBoxLayout:
                            orientation: 'vertical'
                            spacing: dp(6)
                            padding: dp(10)
                            MDCard:
                                md_bg_color: "#691C32"
                                radius: [10]
                                size_hint_y: None
                                height: dp(36)
                                MDLabel:
                                    text: "Prestations à venir"
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: 1,1,1,1
                            ScrollView:
                                MDBoxLayout:
                                    id: upcoming_container
                                    orientation: 'vertical'
                                    adaptive_height: True
                                    spacing: dp(6)
                                    padding: dp(6)
                            MDCard:
                                md_bg_color: "#691C32"
                                radius: [10]
                                size_hint_y: None
                                height: dp(36)
                                MDLabel:
                                    text: "Historique"
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: 1,1,1,1
                            ScrollView:
                                MDBoxLayout:
                                    id: container_prestations
                                    orientation: 'vertical'
                                    adaptive_height: True
                                    spacing: dp(6)
                                    padding: dp(6)

                    MDBottomNavigationItem:
                        name: 'prestation_en_cours'
                        icon: 'clipboard-list-outline'
                        MDBoxLayout:
                            orientation: "vertical"
                            padding: dp(10)
                            spacing: dp(6)
                            MDCard:
                                md_bg_color: "#691C32"
                                radius: [10]
                                size_hint_y: None
                                height: dp(36)
                                MDLabel:
                                    text: "En cours"
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: 1,1,1,1
                            ScrollView:
                                MDBoxLayout:
                                    id: container_en_cours
                                    orientation: "vertical"
                                    adaptive_height: True
                                    spacing: dp(6)
                                    padding: dp(6)

                    MDBottomNavigationItem:
                        name: 'calendar'
                        icon: 'calendar-range'
                        MDScreen:
                            MDTextField:
                                id: field
                                hint_text: "Docked date picker"
                                icon_right: "calendar"
                                pos_hint: {'center_x': .5, 'center_y': .85}
                                size_hint_x: .6
                                on_focus: if self.focus: app.show_date_picker()

                    MDBottomNavigationItem:
                        name: 'profil'
                        icon: 'account'
                        MDBoxLayout:
                            orientation: 'vertical'
                            padding: dp(20)
                            spacing: dp(15)
                            MDLabel:
                                id: profil_nom
                                text: "Nom"
                                halign: "center"
                            MDLabel:
                                id: profil_email
                                text: "Email"
                                halign: "center"
                            MDRaisedButton:
                                text: "Changer le mot de passe"
                                pos_hint: {"center_x": 0.5}
                                on_release: app.show_change_password_screen()

        Screen:
            name: "detail_screen"
            MDBoxLayout:
                orientation: "vertical"
                md_bg_color: 1, 1, 1, 1
                
                ScrollView:
                    MDBoxLayout:
                        orientation: "vertical"
                        padding: dp(20)
                        spacing: dp(12)
                        adaptive_height: True

                        # HEADER
                        MDLabel:
                            id: detail_title
                            text: "Prestation n°--"
                            font_style: "H5"
                            bold: True
                        
                        MDBoxLayout:
                            adaptive_height: True
                            spacing: dp(10)
                            MDLabel:
                                id: detail_subtitle
                                text: "Titre"
                                font_style: "Subtitle1"
                                adaptive_width: True
                            MDLabel:
                                id: detail_status
                                text: "(Status)"
                                theme_text_color: "Custom"
                                text_color: 0.2, 0.3, 1, 1
                                bold: True

                        # SECTIONS
                        MDLabel:
                            text: "👤 Client"
                            theme_text_color: "Hint"
                            font_style: "Caption"
                        MDLabel:
                            id: detail_client
                            text: ""
                            bold: True

                        MDLabel:
                            text: "🛠 Technicien"
                            theme_text_color: "Hint"
                            font_style: "Caption"
                        MDLabel:
                            id: detail_technicien
                            text: ""
                            bold: True

                        MDLabel:
                            text: "📋 Prestation"
                            theme_text_color: "Hint"
                            font_style: "Caption"
                        MDLabel:
                            id: detail_prestation
                            text: ""
                            bold: True

                        MDBoxLayout:
                            spacing: dp(20)
                            size_hint_y: None
                            height: dp(50)
                            MDBoxLayout:
                                orientation: "vertical"
                                MDLabel:
                                    text: "🕒 Date début"
                                    font_style: "Caption"
                                    theme_text_color: "Hint"
                                MDLabel:
                                    id: detail_date_debut
                                    text: ""
                                    bold: True
                            MDBoxLayout:
                                orientation: "vertical"
                                MDLabel:
                                    text: "🕒 Date fin"
                                    font_style: "Caption"
                                    theme_text_color: "Hint"
                                MDLabel:
                                    id: detail_date_fin
                                    text: ""
                                    theme_text_color: "Custom"
                                    text_color: 0.7, 0, 0, 1
                                    underline: True

                        MDLabel:
                            text: "📍 Adresse"
                            theme_text_color: "Hint"
                            font_style: "Caption"
                        MDLabel:
                            id: detail_adresse
                            text: ""
                            bold: True

                        MDLabel:
                            text: "📍 Complément"
                            theme_text_color: "Hint"
                            font_style: "Caption"
                        MDLabel:
                            id: detail_complement
                            text: ""

                        MDLabel:
                            text: "📝 Infos supplémentaires"
                            theme_text_color: "Hint"
                            font_style: "Caption"
                        MDLabel:
                            id: detail_infos
                            text: ""
                            adaptive_height: True

                        MDRaisedButton:
                            id: btn_retour
                            text: "Ajouter un retour"
                            pos_hint: {"center_x": 0.5}
                            md_bg_color: 0.9, 0.9, 0.9, 1
                            text_color: 0, 0, 0, 1
                            on_release: app.go_to_feedback_form()

                        MDRaisedButton:
                            text: "Retour"
                            pos_hint: {"center_x": 0.5}
                            on_release: screen_manager.current = "main_screen"

        Screen:
            name: "feedback_screen"
            MDBoxLayout:
                orientation: "vertical"
                padding: dp(20)
                spacing: dp(15)
                MDLabel:
                    text: "Ajouter un retour"
                    halign: "center"
                    font_style: "H5"
                MDRaisedButton:
                    text: "Ajouter média"
                    pos_hint: {"center_x": .5}
                    on_release: app.add_media()
                MDTextField:
                    id: feedback_description
                    hint_text: "Description"
                    multiline: True
                MDRaisedButton:
                    text: "Valider"
                    pos_hint: {"center_x": .5}
                    on_release: app.submit_feedback()
                MDRaisedButton:
                    text: "Annuler"
                    pos_hint: {"center_x": .5}
                    on_release: app.cancel_feedback()

        Screen:
            name: "change_password_screen"
            MDBoxLayout:
                orientation: "vertical"
                padding: dp(20)
                spacing: dp(20)
                MDTextField:
                    id: current_password
                    hint_text: "Mot de passe actuel"
                    password: True
                MDTextField:
                    id: new_password
                    hint_text: "Nouveau mot de passe"
                    password: True
                MDTextField:
                    id: confirm_password
                    hint_text: "Confirmation"
                    password: True
                MDRaisedButton:
                    id: valider_mdp
                    text: "Valider"
                    pos_hint: {"center_x": .5}
                    on_release: app.valider_mdp()
                    disabled: True