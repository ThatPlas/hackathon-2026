BoxLayout:
    id: root_layout
    orientation: "vertical"
    ScreenManager:
        id: screen_manager

        Screen:
            name: "login_screen"

            MDBoxLayout:
                orientation: "vertical"
                padding: dp(20)
                spacing: dp(20)

                MDTextField:
                    id: login_email
                    hint_text: "Email"

                MDTextField:
                    id: login_password
                    hint_text: "Mot de passe"
                    password: True

                MDRaisedButton:
                    text: "Se connecter"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.tenter_connexion(login_email.text, login_password.text)

                MDLabel:
                    id: login_msg
                    text: ""
                    theme_text_color: "Error"
                    halign: "center"

        Screen:
            name: "main_screen"

            MDScreen:

                MDBottomNavigation:
                    id: nav_bar
                    panel_color: "#F7F5F5"
                    text_color_active: "#691C32"

                    
                    MDBottomNavigationItem:
                        name: 'recherche'
                        icon: 'clipboard-text-clock'

                        MDScrollView:
                            MDBoxLayout:
                                id: container_recherche
                                orientation: 'vertical'
                                adaptive_height: True
                                padding: dp(20)
                                spacing: dp(15)

                   
                    MDBottomNavigationItem:
                        name: 'prestation_en_cours'
                        icon: 'clipboard-list-outline'

                        MDScrollView:
                            MDBoxLayout:
                                id: container_prestations_type
                                orientation: 'vertical'
                                adaptive_height: True
                                padding: dp(20)
                                spacing: dp(20)

                                MDLabel:
                                    text: "Mes prestations en cours"
                                    font_style: "H6"
                                    bold: True
                                    adaptive_height: True

                                MDSeparator:

                                MDLabel:
                                    text: "Mes prestations finis"
                                    font_style: "H6"
                                    bold: True
                                    adaptive_height: True

                    
                    MDBottomNavigationItem:
                        name: 'prestation_historique'
                        icon: 'history'

                        MDScrollView:
                            MDBoxLayout:
                                id: container_prestations
                                orientation: 'vertical'
                                adaptive_height: True
                                padding: dp(20)
                                spacing: dp(15)

                    
                    MDBottomNavigationItem:
                        name: 'calendar'
                        icon: 'calendar-range'

                        MDScreen:
                            md_bg_color: app.theme_cls.bg_normal

                            MDTextField:
                                id: field
                                hint_text: "Docked date picker"
                                helper_text: "MM/DD/YYYY"
                                helper_text_mode: "persistent"
                                icon_right: "calendar"
                                mode: "rectangle"
                                pos_hint: {'center_x': .5, 'center_y': .85}
                                size_hint_x: .5
                                on_focus: if self.focus: app.show_date_picker()

                            MDSeparator:

                            MDRaisedButton:
                                id: button_calendar
                                text: "Valider"
                                pos_hint: {"center_x": 0.5}
                                on_release: app.valider_dates()

                    MDBottomNavigationItem:
                        name: 'profil'
                        icon: 'account'

                        MDScrollView:
                            MDBoxLayout:
                                orientation: 'vertical'
                                adaptive_height: True
                                padding: dp(20)
                                spacing: dp(20)

                                MDBoxLayout:
                                    adaptive_height: True
                                    spacing: dp(20)
                                    FitImage:
                                        source: "profil_logo.png"
                                        size_hint: None, None
                                        size: dp(120), dp(120)
                                        radius: [self.width / 2,]
                                    MDLabel:
                                        text: "Jean-Michel\\nTest"
                                        font_style: "H5"
                                        bold: True
                                        pos_hint: {"center_y": .5}

                                MDSeparator:

                                MDLabel:
                                    text: "Vos dernières prestations"
                                    font_style: "H6"
                                    bold: True
                                    adaptive_height: True

                                MDList:
                                    id: prestations_list

                                MDSeparator:

                                MDLabel:
                                    text: "Profil"
                                    font_style: "H5"
                                    bold: True
                                    halign: "center"

                                MDLabel:
                                    id: profil_nom
                                    text: ""
                                    halign: "center"

                                MDLabel:
                                    id: profil_email
                                    text: ""
                                    halign: "center"