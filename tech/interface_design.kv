#:import dp kivy.metrics.dp

BoxLayout:
    id: root_layout
    orientation: "vertical"

    ScreenManager:
        id: screen_manager

        # --- MAIN ---
        Screen:
            name: "main_screen"
            MDScreen:
                md_bg_color: 0.96, 0.96, 0.96, 1
                MDBottomNavigation:
                    id: nav_bar
                    panel_color: "#F7F5F5"
                    text_color_active: "#691C32"
                    
                    MDBottomNavigationItem:
                        name: 'recherche'
                        icon: 'clipboard-text-clock'
                        MDBoxLayout:
                            orientation: 'vertical'
                            padding: dp(10)
                            spacing: dp(6)
                            MDCard:
                                md_bg_color: "#691C32"
                                size_hint_y: None
                                height: dp(36)
                                MDLabel:
                                    text: "À venir"
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: 1,1,1,1
                            ScrollView:
                                MDBoxLayout:
                                    id: upcoming_container
                                    orientation: 'vertical'
                                    adaptive_height: True
                                    spacing: dp(6)
                            MDCard:
                                md_bg_color: "#691C32"
                                size_hint_y: None
                                height: dp(36)
                                MDLabel:
                                    text: "Historique"
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: 1,1,1,1
                            ScrollView:
                                MDBoxLayout:
                                    id: container_prestations
                                    orientation: 'vertical'
                                    adaptive_height: True
                                    spacing: dp(6)

                    MDBottomNavigationItem:
                        name: 'prestation_en_cours'
                        icon: 'clipboard-list-outline'
                        MDBoxLayout:
                            orientation: "vertical"
                            padding: dp(10)
                            spacing: dp(6)
                            MDCard:
                                md_bg_color: "#691C32"
                                size_hint_y: None
                                height: dp(36)
                                MDLabel:
                                    text: "En cours"
                                    halign: "center"
                                    theme_text_color: "Custom"
                                    text_color: 1,1,1,1
                            ScrollView:
                                MDBoxLayout:
                                    id: container_en_cours
                                    orientation: "vertical"
                                    adaptive_height: True
                                    spacing: dp(6)

                    # --- L'ONGLET CALENDRIER (MODIFIÉ ICI) ---
                    # --- SECTION CALENDRIER MISE À JOUR ---
                    MDBottomNavigationItem:
                        name: 'calendar'
                        icon: 'calendar-range'
                        on_tab_press: app.on_absence_tab_press()
                        
                        ScreenManager:
                            id: absence_manager
                            
                            # Vue du Calendrier (Formulaire)
                            Screen:
                                name: "formulaire_absence"
                                MDBoxLayout:
                                    orientation: 'vertical'
                                    MDTopAppBar:
                                        title: "Nouvelle Absence"
                                        elevation: 0
                                        md_bg_color: "#691C32" # Garde ta couleur
                                        right_action_items: [["history", lambda x: app.switch_absence_screen("liste_absence")]]
                                    
                                    MDScrollView:
                                        MDBoxLayout:
                                            orientation: 'vertical'
                                            padding: dp(15)
                                            spacing: dp(15)
                                            size_hint_y: None
                                            height: self.minimum_height
                                            
                                            MDLabel:
                                                id: info_selection
                                                text: "Sélectionnez une période"
                                                theme_text_color: "Secondary"
                                                font_style: "Caption"
                                                adaptive_height: True
                                            
                                            MDCard:
                                                size_hint: 1, None
                                                # On lie la hauteur du Card à la hauteur de la grille + les contrôles du haut
                                                height: calendar_grid.height + dp(60) 
                                                radius: [dp(15),]
                                                padding: dp(10)
                                                orientation: 'vertical'
                                                elevation: 1
                                                
                                                MDBoxLayout:
                                                    adaptive_height: True
                                                    MDIconButton:
                                                        icon: "chevron-left"
                                                        on_release: app.changer_mois(-1)
                                                    Widget:
                                                    MDFlatButton:
                                                        id: label_mois_annee
                                                        text: ""
                                                    Widget:
                                                    MDIconButton:
                                                        icon: "chevron-right"
                                                        on_release: app.changer_mois(1)
                                                
                                                MDGridLayout:
                                                    id: calendar_grid
                                                    cols: 7
                                                    adaptive_height: True # Important : recalcul automatique
                                                    row_default_height: (self.width / 7) # Force la hauteur des lignes
                                                    row_force_default: True
                                                    spacing: dp(2)
                                            
                                            MDTextField:
                                                id: motif_input
                                                hint_text: "Motif de l'absence..."
                                                mode: "fill"
                                                multiline: True
                                                size_hint_y: None
                                                height: dp(80)
                                            
                                            MDFillRoundFlatButton:
                                                id: btn_envoyer_absence
                                                text: "Envoyer la demande"
                                                size_hint_x: 1
                                                md_bg_color: "#691C32"
                                                disabled: True
                                                on_release: app.envoyer_formulaire_absence()

                            # Vue de l'Historique
                            Screen:
                                name: "liste_absence"
                                MDBoxLayout:
                                    orientation: 'vertical'
                                    MDTopAppBar:
                                        title: "Mes Demandes"
                                        elevation: 0
                                        md_bg_color: "#691C32"
                                        left_action_items: [["arrow-left", lambda x: app.switch_absence_screen("formulaire_absence", "right")]]
                                    MDScrollView:
                                        MDBoxLayout:
                                            id: container_liste_absences
                                            orientation: 'vertical'
                                            padding: dp(15)
                                            spacing: dp(10)
                                            size_hint_y: None
                                            height: self.minimum_height

                    MDBottomNavigationItem:
                        name: 'profil'
                        icon: 'account'
                        MDBoxLayout:
                            orientation: 'vertical'
                            padding: dp(20)
                            spacing: dp(10)
                            MDLabel:
                                id: profil_nom
                                halign: "center"
                            MDLabel:
                                id: profil_email
                                halign: "center"
                            MDRaisedButton:
                                text: "Changer le mot de passe"
                                pos_hint: {"center_x": 0.5}
                                on_release: app.show_change_password_screen()

        # --- DETAIL : EN COURS ---
        Screen:
            name: "detail_en_cours"
            MDBoxLayout:
                orientation: "vertical"
                md_bg_color: 1,1,1,1
                ScrollView:
                    MDBoxLayout:
                        orientation: "vertical"
                        padding: [dp(25), dp(20), dp(25), dp(20)]
                        spacing: dp(15)
                        adaptive_height: True
                        MDLabel:
                            id: ec_title
                            font_style: "H5"
                            bold: True
                            adaptive_height: True
                        MDBoxLayout:
                            adaptive_height: True
                            spacing: dp(10)
                            MDLabel:
                                id: ec_subtitle
                                font_style: "Subtitle1"
                                adaptive_width: True
                            MDLabel:
                                text: "(En cours)"
                                font_style: "Subtitle1"
                                theme_text_color: "Custom"
                                text_color: 0.2, 0.4, 0.9, 1
                                bold: True
                        MDBoxLayout:
                            orientation: "vertical"
                            adaptive_height: True
                            spacing: dp(12)
                            MDBoxLayout:
                                orientation: "vertical"
                                adaptive_height: True
                                MDLabel:
                                    text: "👤 Client"
                                    theme_text_color: "Hint"
                                    font_style: "Caption"
                                MDLabel:
                                    id: ec_client
                                    bold: True
                            MDBoxLayout:
                                orientation: "vertical"
                                adaptive_height: True
                                MDLabel:
                                    text: "🛠 Technicien"
                                    theme_text_color: "Hint"
                                    font_style: "Caption"
                                MDLabel:
                                    id: ec_technicien
                                    bold: True
                            MDBoxLayout:
                                adaptive_height: True
                                spacing: dp(20)
                                MDBoxLayout:
                                    orientation: "vertical"
                                    adaptive_height: True
                                    MDLabel:
                                        text: "🕒 Date début"
                                        theme_text_color: "Hint"
                                        font_style: "Caption"
                                    MDLabel:
                                        id: ec_date_debut
                                        bold: True
                                MDBoxLayout:
                                    orientation: "vertical"
                                    adaptive_height: True
                                    MDLabel:
                                        text: "🕒 Date fin"
                                        theme_text_color: "Hint"
                                        font_style: "Caption"
                                    MDLabel:
                                        id: ec_date_fin
                                        bold: True
                                        theme_text_color: "Custom"
                                        text_color: 0.8, 0, 0, 1
                                        underline: True
                            MDBoxLayout:
                                orientation: "vertical"
                                adaptive_height: True
                                MDLabel:
                                    text: "📍 Adresse"
                                    theme_text_color: "Hint"
                                    font_style: "Caption"
                                MDLabel:
                                    id: ec_adresse
                                    bold: True
                            MDBoxLayout:
                                orientation: "vertical"
                                adaptive_height: True
                                MDLabel:
                                    text: "📍 Complément"
                                    theme_text_color: "Hint"
                                    font_style: "Caption"
                                MDLabel:
                                    id: ec_complement
                            MDBoxLayout:
                                orientation: "vertical"
                                adaptive_height: True
                                MDLabel:
                                    text: "📝 Infos supplémentaires"
                                    theme_text_color: "Hint"
                                    font_style: "Caption"
                                MDLabel:
                                    id: ec_infos
                                    adaptive_height: True
                        Widget:
                            size_hint_y: None
                            height: dp(20)
                        MDRaisedButton:
                            text: "Ajouter un retour"
                            pos_hint: {"center_x": 0.5}
                            size_hint_x: 0.9
                            md_bg_color: 0.9, 0.9, 0.9, 1
                            text_color: 0, 0, 0, 1
                            on_release: app.go_to_feedback_form()
                        MDRaisedButton:
                            text: "Retour"
                            pos_hint: {"center_x": 0.5}
                            size_hint_x: 0.9
                            md_bg_color: "#691C32"
                            on_release: screen_manager.current = "main_screen"

        # --- DETAIL : A VENIR ---
        Screen:
            name: "detail_a_venir"
            MDBoxLayout:
                orientation: "vertical"
                padding: dp(20)
                spacing: dp(10)
                MDLabel:
                    id: av_title
                    font_style: "H5"
                    bold: True
                    adaptive_height: True
                MDLabel:
                    id: av_subtitle
                    adaptive_height: True
                MDLabel:
                    id: av_client
                    adaptive_height: True
                MDLabel:
                    id: av_technicien
                    adaptive_height: True
                MDLabel:
                    id: av_adresse
                    adaptive_height: True
                MDLabel:
                    id: av_infos
                    adaptive_height: True
                MDRaisedButton:
                    text: "Retour"
                    pos_hint: {"center_x": 0.5}
                    on_release: screen_manager.current = "main_screen"

        # --- DETAIL : HISTORIQUE ---
        Screen:
            name: "detail_historique"
            MDBoxLayout:
                orientation: "vertical"
                padding: dp(20)
                spacing: dp(10)
                MDLabel:
                    id: hi_title
                    font_style: "H5"
                    bold: True
                    adaptive_height: True
                MDLabel:
                    id: hi_subtitle
                    adaptive_height: True
                MDLabel:
                    id: hi_client
                    adaptive_height: True
                MDLabel:
                    id: hi_technicien
                    adaptive_height: True
                MDLabel:
                    id: hi_adresse
                    adaptive_height: True
                MDLabel:
                    id: hi_infos
                    adaptive_height: True
                MDRaisedButton:
                    text: "Retour"
                    pos_hint: {"center_x": 0.5}
                    on_release: screen_manager.current = "main_screen"

        # --- FEEDBACK ---
        Screen:
            name: "feedback_screen"
            MDBoxLayout:
                orientation: "vertical"
                padding: dp(20)
                spacing: dp(15)
                MDLabel:
                    text: "Feedback"
                    halign: "center"
                MDTextField:
                    id: feedback_description
                    hint_text: "Description"
                    multiline: True
                MDRaisedButton:
                    text: "Valider"
                    on_release: app.submit_feedback()
                MDRaisedButton:
                    text: "Annuler"
                    on_release: app.cancel_feedback()

        # --- PASSWORD ---
        Screen:
            name: "change_password_screen"
            MDBoxLayout:
                orientation: "vertical"
                padding: dp(20)
                spacing: dp(20)
                MDTextField:
                    id: current_password
                    hint_text: "Actuel"
                    password: True
                MDTextField:
                    id: new_password
                    hint_text: "Nouveau"
                    password: True
                MDTextField:
                    id: confirm_password
                    hint_text: "Confirmer"
                    password: True
                MDRaisedButton:
                    id: valider_mdp
                    text: "Valider"
                    disabled: True
                    on_release: app.valider_mdp()