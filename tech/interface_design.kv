MDScreen:

    MDBottomNavigation:
        id: nav_bar
        panel_color: "#F7F5F5"
        text_color_active: "#691C32"

        MDBottomNavigationItem:
            name:'Recherche'
            icon:'clipboard-text-clock'

        MDBottomNavigationItem:
            name:'prestation_en_cours'
            icon:'clipboard-list-outline'

            MDBoxLayout:
                id: container_prestations_type
                orientation: 'vertical'
                adaptive_height: True
                padding: dp(20)
                spacing: dp(20)

                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_height: True
                    padding: dp(20)
                    spacing: dp(20)
                    
                    MDLabel:
                        text: "Mes prestations en cours"
                        font_style: "H6"
                        bold: True
                        adaptive_height: True

                MDSeparator:

                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_height: True
                    padding: dp(20)
                    spacing: dp(20)
                    
                    MDLabel:
                        text: "Mes prestations fini"
                        font_style: "H6"
                        bold: True
                        adaptive_height: True


        MDBottomNavigationItem:
            name:'prestation_historique'
            icon:'history'

            MDScrollView:
                MDBoxLayout:
                    id: container_prestations
                    orientation: 'vertical'
                    adaptive_height: True
                    padding: dp(20)
                    spacing: dp(15)

        MDBottomNavigationItem:
            name:'calendar'
            icon:'calendar-range'
            MDScreen:
                md_bg_color: app.theme_cls.bg_normal

                MDTextField:
                    id: field
                    hint_text: "Docked date picker"
                    helper_text: "MM/DD/YYYY"
                    helper_text_mode: "persistent"
                    icon_right: "calendar"
                    mode: "rectangle"
                    pos_hint: {'center_x': .5, 'center_y': .85}
                    size_hint_x: .5
                    on_focus: if self.focus: app.show_date_picker()
                MDSeparator:

                MDRaisedButton:
                    id: button_calendar
                    text: "Valider"
                    pos_hint: {"center_x": 0.5}
                    on_release: app.valider_dates()

        MDBottomNavigationItem:
            name:'profil'
            text: 'Profil'
            icon: 'account'
            MDScrollView:
                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_height: True
                    padding: dp(20)
                    spacing: dp(20)

                    MDBoxLayout:
                        adaptive_height: True
                        spacing: dp(20)
                        FitImage:
                            source: "profil_logo.png"
                            size_hint: None, None
                            size: dp(120), dp(120)
                            radius: [self.width / 2,]
                        MDLabel:
                            text: "Jean-Michel\\nTest"
                            font_style: "H5"
                            bold: True
                            pos_hint: {"center_y": .5}

                    MDSeparator:

                    MDLabel:
                        text: "Vos dernières prestations"
                        font_style: "H6"
                        bold: True
                        adaptive_height: True

                    MDList:
                        id: prestations_list
        MDBottomNavigationItem:
            name:'connexion'
            text: 'Connexion'
            icon: 'account'
            MDBoxLayout:
                orientation: "vertical"
                padding: "20dp"
                spacing: "15dp"
                pos_hint: {"center_y": 0.5}
                adaptive_height: True

                MDLabel:
                    text: "Créer un compte"
                    font_style: "H4"
                    halign: "center"
                    bold: True
                    theme_text_color: "Primary"

                MDTextField:
                    id: champ_nom_insc
                    hint_text: "Nom"
                    mode: "rectangle"

                MDTextField:
                    id: champ_prenom_insc
                    hint_text: "Prénom"
                    mode: "rectangle"

                MDTextField:
                    id: champ_email_insc
                    hint_text: "Adresse Email"
                    icon_right: "email"
                    mode: "rectangle"

                MDTextField:
                    id: champ_mdp_insc
                    hint_text: "Mot de passe"
                    icon_right: "eye-off"
                    mode: "rectangle"
                    password: True

                MDLabel:
                    id: message_erreur_insc
                    text: ""
                    theme_text_color: "Error" # Devient vert en cas de succès
                    halign: "center"
                    size_hint_y: None
                    height: self.texture_size[1]

                MDRaisedButton:
                    text: "S'INSCRIRE"
                    pos_hint: {"center_x": 0.5}
                    size_hint_x: 0.8
                    md_bg_color: "#691C32"
                    on_release: app.tenter_inscription(champ_nom_insc.text, champ_prenom_insc.text, champ_email_insc.text, champ_mdp_insc.text)

                MDTextButton:
                    text: "Déjà un compte ? Se connecter"
                    pos_hint: {"center_x": 0.5}
                    theme_text_color: "Secondary"
                    on_release: app.aller_a_connexion()

        

        