#:include utilisateur/profil/profil.kv
#:include recherche/Recherche.kv

MDScreen:
    name: "espace_client"

    MDBottomNavigation:
        id: nav_bar
        panel_color: "#F7F5F5"
        text_color_active: "#691C32"

        # ==========================================
        # --- ONGLET 1 : RECHERCHE ---
        # ==========================================
        MDBottomNavigationItem:
            name: 'page_recherche'
            text: 'Rechercher'
            icon: 'magnify'
            
            RechercheContent:
                id: contenu_recherche

        # ==========================================
        # --- ONGLET 2 : ACCUEIL ---
        # ==========================================
        MDBottomNavigationItem:
            name: 'page_accueil'
            text: 'Accueil'
            icon: 'home-outline'

            MDFloatLayout:
                md_bg_color: 1, 1, 1, 1

                MDScrollView:
                    MDBoxLayout:
                        orientation: 'vertical'
                        adaptive_height: True
                        padding: dp(20)
                        spacing: dp(20)

                        Image:
                            source: '../../logo.png'
                            size_hint_y: None
                            height: dp(120)
                            allow_stretch: True
                            keep_ratio: True
                        
                        MDLabel:
                            text: "SIMPLIFIEZ VOTRE QUOTIDIEN GRÂCE À NOTRE SERVICE DE CONCIERGERIE DANS LE NORD-PAS-DE-CALAIS"
                            theme_text_color: "Custom"
                            text_color: 0.46, 0.14, 0.24, 1
                            font_style: "H5"
                            bold: True
                            adaptive_height: True
                            halign: 'center'
                            
                        MDLabel:
                            text: "Vous avez récemment acheté un appartement que vous souhaitez mettre en location et vous désirez déléguer sa gestion ? Vous cherchez un service flexible et disponible, qui vous permettra de gagner un temps précieux ?\nConciergerie Desruelle est à votre disposition.\nProfitez de notre solide expérience professionnelle et découvrez notre gamme de services."
                            theme_text_color: "Secondary"
                            font_style: "Body1"
                            adaptive_height: True
                            line_height: 1.2
                            halign: 'center'
                        
                        MDSeparator:
                            height: "1dp"

                        MDLabel:
                            text: "DE NOMBREUX SERVICES"
                            theme_text_color: "Custom"
                            text_color: 0.46, 0.14, 0.24, 1
                            font_style: "H5"
                            bold: True
                            adaptive_height: True

                        MDCard:
                            orientation: 'vertical'
                            padding: dp(20)
                            spacing: dp(12)
                            size_hint_y: None
                            height: self.minimum_height
                            elevation: 1
                            radius: [dp(8), dp(8), dp(8), dp(8)]
                            md_bg_color: 1, 1, 1, 1
                            MDIcon:
                                icon: "clipboard-check-outline"
                                theme_text_color: "Custom"
                                text_color: 0.46, 0.14, 0.24, 1
                                font_size: dp(40)
                            MDLabel:
                                text: "Gestion locative :"
                                theme_text_color: "Custom"
                                text_color: 0.46, 0.14, 0.24, 1
                                font_style: "Subtitle1"
                                bold: True
                                adaptive_height: True
                            MDLabel:
                                text: "recherche de locataires, sélection des dossiers, rédaction de bail, état des lieux entrant et sortant, remise des clés, relance en cas de loyers impayés..."
                                theme_text_color: "Secondary"
                                font_style: "Body1"
                                adaptive_height: True
                                line_height: 1.2

                        MDCard:
                            orientation: 'vertical'
                            padding: dp(20)
                            spacing: dp(12)
                            size_hint_y: None
                            height: self.minimum_height
                            elevation: 1
                            radius: [dp(8), dp(8), dp(8), dp(8)]
                            md_bg_color: 1, 1, 1, 1
                            MDIcon:
                                icon: "toolbox-outline"
                                theme_text_color: "Custom"
                                text_color: 0.46, 0.14, 0.24, 1
                                font_size: dp(40)
                            MDLabel:
                                text: "Maintenance :"
                                theme_text_color: "Custom"
                                text_color: 0.46, 0.14, 0.24, 1
                                font_style: "Subtitle1"
                                bold: True
                                adaptive_height: True
                            MDLabel:
                                text: "petits travaux d’électricité, de plomberie, remplacement d’équipement et électroménager..."
                                theme_text_color: "Secondary"
                                font_style: "Body1"
                                adaptive_height: True
                                line_height: 1.2

                        MDCard:
                            orientation: 'vertical'
                            padding: dp(20)
                            spacing: dp(12)
                            size_hint_y: None
                            height: self.minimum_height
                            elevation: 1
                            radius: [dp(8), dp(8), dp(8), dp(8)]
                            md_bg_color: 1, 1, 1, 1
                            MDIcon:
                                icon: "vacuum-outline"
                                theme_text_color: "Custom"
                                text_color: 0.46, 0.14, 0.24, 1
                                font_size: dp(40)
                            MDLabel:
                                text: "Entretien et nettoyage :"
                                theme_text_color: "Custom"
                                text_color: 0.46, 0.14, 0.24, 1
                                font_style: "Subtitle1"
                                bold: True
                                adaptive_height: True
                            MDLabel:
                                text: "maisons et appartements, locaux commerciaux, immeubles et bâtiments collectifs, vitres…"
                                theme_text_color: "Secondary"
                                font_style: "Body1"
                                adaptive_height: True
                                line_height: 1.2

                        MDSeparator:
                            height: "1dp"

                        MDLabel:
                            text: "UNE HISTOIRE DE FAMILLE ET UN DÉVOUEMENT SINCÈRE ENVERS NOS CLIENTS"
                            theme_text_color: "Custom"
                            text_color: 0.46, 0.14, 0.24, 1
                            font_style: "H5"
                            bold: True
                            adaptive_height: True

                        MDLabel:
                            text: "Franck et Antoine Desruelle ont toujours eu en eux le sens du service mais c’est entre deux vagues de la pandémie de Covid19 qu’ils ont finalement décidé de lancer leur entreprise à taille humaine.\nDepuis 2020, ils s’adressent à une clientèle variée qui se compose de particuliers, d’entreprises, de syndics ou encore de collectivités."
                            theme_text_color: "Secondary"
                            font_style: "Body1"
                            adaptive_height: True
                            line_height: 1.2

                        FitImage:
                            source: '../../images/accueil/famille.jpg'
                            size_hint_y: None
                            height: dp(220)
                            radius: [dp(8), dp(8), dp(8), dp(8)]

                        MDLabel:
                            text: "NOTRE ZONE DE CHALANDISE AUTOUR DE LA VILLE DE LILLE"
                            theme_text_color: "Custom"
                            text_color: 0.46, 0.14, 0.24, 1
                            font_style: "H5"
                            bold: True
                            adaptive_height: True

                        MDLabel:
                            text: "Notre conciergerie est située à Lille (59160), dans le Nord. Toutefois, nos clients peuvent nous solliciter depuis l’intégralité de la métropole lilloise ainsi que de nombreuses communes alentours : Loos, Ronchin, La Madeleine et plus encore.\nFaites-nous confiance pour le nettoyage courant de votre logement, des petits travaux de rénovation dans votre maison, l’accompagnement de voyageurs pendant leur séjour à Lille et bien d'autres prestations.\nVous hésitez encore à profiter de notre offre de services ? Lisez les avis authentiques des clients qui ont déjà fait appel à notre conciergerie."
                            theme_text_color: "Secondary"
                            font_style: "Body1"
                            adaptive_height: True
                            line_height: 1.2

                        FitImage:
                            source: '../../images/accueil/grandplace.jpg'
                            size_hint_y: None
                            height: dp(220)
                            radius: [dp(8), dp(8), dp(8), dp(8)]
                            
                        MDLabel:
                            text: "141 Rue Henri Ghesquiere, 59160 Lille"
                            theme_text_color: "Secondary"
                            font_style: "Body1"
                            adaptive_height: True
                            line_height: 1.2
                            
                        FitImage:
                            source: '../../images/accueil/endroit.png'
                            size_hint_y: None
                            height: dp(220)
                            radius: [dp(8), dp(8), dp(8), dp(8)]
                        
                        MDFillRoundFlatButton:
                            text: "PARCOURIR LES SERVICES"
                            md_bg_color: 0.46, 0.14, 0.24, 1
                            text_color: 1, 1, 1, 1
                            font_size: dp(18)
                            font_style: "Body1"
                            bold: True
                            padding: [dp(24), dp(12), dp(24), dp(12)]
                            radius: [dp(8), dp(8), dp(8), dp(8)]
                            pos_hint: {"center_x": .5}
                            on_release: nav_bar.switch_tab('page_recherche') 

        # ==========================================
        # --- ONGLET 3 : PROFIL ---
        # ==========================================
        MDBottomNavigationItem:
            name: 'page_profil'
            text: 'Profil'
            icon: 'account'
            
            ProfilContent:
                id: contenu_profil