MDScreen:
    name: "page_modifier_profil"
    md_bg_color: "#F7F5F5"

    MDBoxLayout:
        orientation: 'vertical'

        # Barre du haut
        MDTopAppBar:
            title: "Modifier mes infos"
            anchor_title: "center"
            elevation: 0
            md_bg_color: "#691C32"
            left_action_items: [["arrow-left", lambda x: app.retour_profil()]]
            right_action_items: [["check", lambda x: app.sauvegarder_profil()]]

        MDScrollView:
            MDBoxLayout:
                orientation: 'vertical'
                adaptive_height: True
                padding: dp(30)
                spacing: dp(20)

                MDTextField:
                    id: modif_nom
                    hint_text: "Nom"
                    mode: "rectangle"

                MDTextField:
                    id: modif_prenom
                    hint_text: "Prénom"
                    mode: "rectangle"

                MDTextField:
                    id: modif_email
                    hint_text: "Adresse Email"
                    icon_right: "email"
                    mode: "rectangle"

                MDTextField:
                    id: modif_tel
                    hint_text: "Téléphone"
                    icon_right: "phone"
                    mode: "rectangle"

                MDTextField:
                    id: modif_adresse
                    hint_text: "Adresse de résidence"
                    icon_right: "map-marker"
                    mode: "rectangle"